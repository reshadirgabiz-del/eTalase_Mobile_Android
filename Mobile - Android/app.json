{
  "expo": {
    "name": "e-Talase",
    "slug": "etalase-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./UI:UX/assets/favicon.png",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.etalase.mobile",
      "infoPlist": {
        "NSCameraUsageDescription": "Diperlukan untuk scan QR login dan mengambil foto bukti pengiriman",
        "NSPhotoLibraryUsageDescription": "Diperlukan untuk memilih foto bukti pengiriman"
      }
    },
    "android": {
      "package": "com.etalase.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./UI:UX/assets/android-adaptive-icon-foreground.png",
        "backgroundColor": "#F6F3EC"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Diperlukan untuk scan QR login"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Diperlukan untuk memilih foto bukti pengiriman",
          "cameraPermission": "Diperlukan untuk mengambil foto bukti pengiriman"
        }
      ],
      "expo-web-browser",
      "expo-font",
      [
        "expo-notifications",
        {
          "color": "#1A1A18"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./UI:UX/assets/favicon.png",
          "imageWidth": 168,
          "resizeMode": "contain",
          "backgroundColor": "#F6F3EC"
        }
      ]
    ],
    "scheme": "etalase",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "cec1ce5b-5349-4463-9de6-cb7e59c12853"
      }
    },
    "owner": "blackromantic"
  }
}
