# ── Server ───────────────────────────────────────────────────────────────────
# PORT is not used on Netlify (serverless), but kept for local dev
PORT=3001
# Local: http://localhost:3000  |  Production: https://your-frontend-domain.com
CORS_ORIGIN=http://localhost:3000

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ── Clerk ────────────────────────────────────────────────────────────────────
CLERK_SECRET_KEY=sk_test_xxxx
CLERK_WEBHOOK_SECRET=whsec_xxxx

# ── Midtrans ─────────────────────────────────────────────────────────────────
# false = sandbox  |  true = production
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxx

# ── Biteship ─────────────────────────────────────────────────────────────────
BITESHIP_API_KEY=biteship-sandbox.xxxx
BITESHIP_API_URL=https://api.biteship.com/v1
